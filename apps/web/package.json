{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "next lint --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "generate:whitepaper": "node scripts/generate-whitepaper.mjs",
    "ingest:content": "tsx --env-file=../../.env.local scripts/ingest-content.ts",
    "clean": "rm -rf .next .turbo node_modules"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@portabletext/react": "^3.1.0",
    "@propharmex/lib": "workspace:*",
    "@propharmex/ui": "workspace:*",
    "@sanity/client": "^6.22.0",
    "@sanity/image-url": "^1.0.2",
    "@supabase/supabase-js": "^2.45.0",
    "@upstash/ratelimit": "^2.0.0",
    "@sentry/nextjs": "^8.40.0",
    "@upstash/redis": "^1.34.0",
    "ai": "^4.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.451.0",
    "next": "^15.0.0",
    "next-sanity": "^9.8.0",
    "plausible-tracker": "^0.3.9",
    "posthog-js": "^1.160.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.0",
    "@react-email/components": "^0.0.25",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@propharmex/config": "workspace:*",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.16.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.11.0",
    "eslint-config-next": "^15.0.0",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
