{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm --filter web start",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/why-propharmex",
        "http://localhost:3000/quality-compliance",
        "http://localhost:3000/services/pharmaceutical-development",
        "http://localhost:3000/services/pharmaceutical-development/solid-oral-dosage",
        "http://localhost:3000/insights",
        "http://localhost:3000/insights/del-at-a-glance-foreign-sponsor-primer",
        "http://localhost:3000/case-studies",
        "http://localhost:3000/contact",
        "http://localhost:3000/ai/del-readiness"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "emulatedFormFactor": "mobile",
        "throttlingMethod": "simulate",
        "skipAudits": [
          "uses-http2",
          "is-crawlable",
          "valid-source-maps"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.90, "aggregationMethod": "median-run" }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2000, "aggregationMethod": "median-run" }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05, "aggregationMethod": "median-run" }],
        "total-blocking-time": ["error", { "maxNumericValue": 200, "aggregationMethod": "median-run" }],
        "first-contentful-paint": ["error", { "maxNumericValue": 1800, "aggregationMethod": "median-run" }],
        "interactive": ["warn", { "maxNumericValue": 3000, "aggregationMethod": "median-run" }],
        "speed-index": ["warn", { "maxNumericValue": 3400, "aggregationMethod": "median-run" }],
        "categories:accessibility": ["warn", { "minScore": 0.95, "aggregationMethod": "median-run" }],
        "categories:best-practices": ["warn", { "minScore": 0.95, "aggregationMethod": "median-run" }],
        "categories:seo": ["warn", { "minScore": 0.85, "aggregationMethod": "median-run" }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
