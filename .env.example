# =============================================================================
# Propharmex website — environment spec
# Copy to .env.local (for local dev) or configure via Vercel env UI (prod).
# NEVER commit .env.local or .env.production.
# Values are placeholders only. Comments explain which phase/prompt needs each.
# =============================================================================

# --- Anthropic (AI Phase 7: all 4 AI tools) ---
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (Phase 7: embeddings + GPT-4o fallback) ---
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Supabase (Phase 3: CMS-adjacent storage + Phase 7: pgvector RAG) ---
# Create free project at: https://supabase.com/dashboard
# Run `create extension vector;` in the SQL editor once created.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# Pooled Postgres connection (server-side usage only)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# --- Sanity (Phase 3: CMS) ---
# Create project at: https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
SANITY_WEBHOOK_SECRET=generate-long-random-string
# Preview / draft-mode secret (Phase 3)
SANITY_PREVIEW_SECRET=generate-long-random-string

# --- Resend (Phase 3: newsletter + Phase 7: contact form + Phase 6: whitepaper gating) ---
# Get at: https://resend.com/
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Propharmex <hello@propharmex.com>"
RESEND_CONTACT_TO_EMAIL=hello@propharmex.com
RESEND_NEWSLETTER_AUDIENCE_ID=

# --- Cal.com (Phase 7: contact page + DEL Readiness booking) ---
# Get at: https://cal.com/
CAL_LINK=propharmex/discovery-15
CAL_EVENT_TYPE_ID=

# --- Analytics ---
# Plausible (Phase 8): https://plausible.io/
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=propharmex.com
# PostHog (Phase 8): https://posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Cloudflare Turnstile (Phase 7: contact form + AI tool forms) ---
# Get at: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Upstash Redis (Phase 7: rate limiting on /api/ai/*) ---
# Get at: https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (Phase 9: error tracking) ---
# Get at: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=propharmex
SENTRY_PROJECT=web

# --- Axiom (Phase 9: structured logs) - optional if Sentry covers logs ---
AXIOM_TOKEN=
AXIOM_DATASET=propharmex-web

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=https://propharmex.com

# --- Vercel-only (injected automatically in Vercel envs) ---
# VERCEL_ENV=preview|production|development
# VERCEL_URL=auto-injected
# VERCEL_REGION=auto-injected
